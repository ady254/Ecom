# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/minara?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=minaragifting01@gmail.com
EMAIL_PASS=your_gmail_app_password
# Must be the authenticated Gmail account (or a verified alias) — Gmail rewrites
# or refuses any other sender, so don't put noreply@minaragifting.com here.
EMAIL_FROM="MINARA <minaragifting01@gmail.com>"

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── Cookies ──────────────────────────────────────────────────────────────────
# 'lax' when API + store share a domain (api.minaragifting.com + minaragifting.com — recommended).
# 'none' ONLY if they are on completely different domains (e.g. onrender.com +
# minaragifting.com). Avoid it: the refresh cookie then becomes a third-party cookie,
# which Safari/iOS blocks by default, silently logging users out every 15 minutes.
COOKIE_SAMESITE=lax

# ─── Admin Seeding (required in production) ───────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=choose_a_strong_password
SEED_ADMIN_NAME=Store Admin
